# .env.example
# Copy this file to .env and adjust values for your environment

# Environment
ENVIRONMENT=development
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=moderator
DB_PASSWORD=moderator123
DB_NAME=content_moderator
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# NATS
NATS_HOST=localhost
NATS_PORT=4222

# Triton Inference Server (Phase 2)
TRITON_HOST=localhost
TRITON_PORT=8001

# Server
HTTP_PORT=8080
GRPC_PORT=9090
PPROF_PORT=6060

# Jeager
JAEGER_ENDPOINT=jaeger:4317