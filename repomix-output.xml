    image: nats:2.10-alpine
    container_name: moderator-nats
    command: "-js -m 8222 --server_name moderator-nats"
    ports:
      - "${NATS_PORT}:4222"
      - "8222:8222"
    volumes:
      - nats-data:/data
    healthcheck:
      test: ["CMD-SHELL", "wget --spider --quiet http://localhost:8222/healthz || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s
