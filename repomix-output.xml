syntax = "proto3";

package content;

option go_package = "github.com/mohammadpnp/content-moderator/api/content;content";

import "google/protobuf/timestamp.proto";

// ContentService defines RPCs for managing user content.
service ContentService {
  // CreateContent creates a new content item and returns it.
  rpc CreateContent(CreateContentRequest) returns (CreateContentResponse);

  // GetContent retrieves a single content item by ID.
  rpc GetContent(GetContentRequest) returns (GetContentResponse);

  // StreamModerationResults streams moderation results for a user's content.
  // The server pushes results as they become available.
  rpc StreamModerationResults(StreamModerationResultsRequest) returns (stream ModerationResult);
}

// --- Message types ---

enum ContentType {
  CONTENT_TYPE_UNSPECIFIED = 0;
  CONTENT_TYPE_TEXT = 1;
  CONTENT_TYPE_IMAGE = 2;
}

enum ContentStatus {
  CONTENT_STATUS_UNSPECIFIED = 0;
  CONTENT_STATUS_PENDING = 1;
  CONTENT_STATUS_APPROVED = 2;
  CONTENT_STATUS_REJECTED = 3;
}

message Content {
  string id = 1;
  string user_id = 2;
  ContentType type = 3;
  string body = 4;
  ContentStatus status = 5;
  optional string moderation_id = 6;
  google.protobuf.Timestamp created_at = 7;
  google.protobuf.Timestamp updated_at = 8;
}

message ModerationResult {
  string id = 1;
  string content_id = 2;
  bool is_approved = 3;
  double score = 4;
  repeated string categories = 5; // e.g., "hate", "spam"
  string model_name = 6;
  int64 duration_ms = 7;
  google.protobuf.Timestamp created_at = 8;
}

// --- Request / Response messages ---

message CreateContentRequest {
  string user_id = 1;
  ContentType type = 2;
  string body = 3;
}

message CreateContentResponse {
  Content content = 1;
}

message GetContentRequest {
  string id = 1;
}

message GetContentResponse {
  Content content = 1;
}

message StreamModerationResultsRequest {
  string user_id = 1;
}
</file>

<file path="api/moderation_service.proto">
syntax = "proto3";

package moderation;

option go_package = "github.com/mohammadpnp/content-moderator/api/moderation;moderation";

import "google/protobuf/timestamp.proto";

service ModerationService {
  // ModerateContent performs bidirectional streaming moderation.
  // The client sends content identifiers and receives moderation results.
  rpc ModerateContent(stream ModerateContentRequest) returns (stream ModerateContentResponse);

  // GetModelHealth returns the health status of the AI model.
  rpc GetModelHealth(GetModelHealthRequest) returns (GetModelHealthResponse);
}

// --- Message types ---

message ModerateContentRequest {
  string content_id = 1;
  string content_type = 2;  // "text" or "image"
  string body = 3;          // actual text or image URL
}

message ModerateContentResponse {
  string content_id = 1;
  ModerationResult result = 2;
}

message ModerationResult {
  string id = 1;
  string content_id = 2;
  bool is_approved = 3;
  double score = 4;
  repeated string categories = 5;
  string model_name = 6;
  int64 duration_ms = 7;
  google.protobuf.Timestamp created_at = 8;
}

message GetModelHealthRequest {}

message GetModelHealthResponse {
  bool healthy = 1;
}
</file>

<file path="api/TRITON_INTEGRATION.md">
# Triton Inference Server – Integration Summary

## موقعیت در پروژه
پوشهٔ `api/triton/` شامل کدهای خودکار تولیدشده از فایل‌های `.proto` سرور NVIDIA Triton است.  
به دلیل حجم بسیار بالای این فایل‌ها (تنها `model_config.pb.go` بیش از ۱۲٬۰۰۰ خط)، این پوشه در فایل `.repomixignore` قرار گرفته و از خروجی Repomix حذف شده است.

## محتوای پوشه (خلاصه)
- **پروتوهای اصلی Triton:**  
  `grpc_service.proto`, `health.proto`, `model_config.proto`  
- **فایل‌های تولیدشدهٔ Go (gRPC و Protobuf):**  
  - `grpc_service.pb.go`, `grpc_service_grpc.pb.go`  
  - `health.pb.go`, `health_grpc.pb.go`  
  - `model_config.pb.go`

## مدل‌های استفاده‌شده در پروژه
| مدل                | هدف                 |
| ------------------ | ------------------- |
| `text_moderation`  | تشخیص محتوای متنی   |
| `image_moderation` | تشخیص محتوای تصویری |

## ساختار درخواست استنتاج (ModelInfer)
- **نام تنسور ورودی متن:** `text_input`  
- **نام تنسور ورودی تصویر:** `image_input`  
- **نوع داده:** `BYTES`  
- **Shape:** `[1]`  
- **تنسورهای خروجی درخواستی:**  
  - `probabilities` (نوع `FP32`، مقدار احتمال)  
  - `categories` (نوع `BYTES`، دسته‌بندی‌ها با جداکنندهٔ کاما)

## مدارشکن (Circuit Breaker)
کلاینت Triton از طریق یک Wrapper به نام `CircuitBreakerAIClient` محافظت می‌شود.  
تنظیمات:
- باز شدن مدار پس از ۵ خطا در ۶۰ ثانیه (با نسبت شکست ≥ ۶۰٪)
- ۳ درخواست آزمایشی در حالت نیمه‌باز
- زمان باز ماندن مدار: ۳۰ ثانیه
- بازنشانی شمارنده‌ها: هر ۶۰ ثانیه

## پیاده‌سازی‌های دستی
کدهایی که مستقیماً به Triton مربوط می‌شوند و توسط تیم نوشته شده‌اند:
- `internal/adapter/outbound/triton/client.go`  
- `internal/adapter/outbound/triton/circuit_breaker.go`

## یادداشت
برای تحلیل‌های بعدی، اطلاعات فنی کامل در همین فایل موجود است و نیازی به مشاهدهٔ کدهای generated نیست.
</file>

