func TestCircuitBreaker_OpensAfterFailures(t *testing.T) {
	client := triton.NewCircuitBreakerAIClient(&failingAIClient{})

	ctx := context.Background()
	// ۵ تا خطا باعث باز شدن مدار می‌شود
